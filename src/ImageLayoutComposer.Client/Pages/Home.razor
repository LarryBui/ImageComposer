@page "/"
@using ImageLayoutComposer.Shared
@using ImageLayoutComposer.Shared.Models
@using ImageLayoutComposer.Client.Services
@inject ApiService ApiService

<PageTitle>Image Layout Composer</PageTitle>

<div class="container mt-4">
    <h1>Image Uploads</h1>
    <p>Upload your images here and then go to the "Compose" page to create your grid.</p>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Upload New Images</h5>
            
            <div class="row g-3 align-items-center mb-3">
                <div class="col-auto">
                    <label for="patientName" class="col-form-label">Patient Name:</label>
                </div>
                <div class="col-md-4">
                    <input type="text" id="patientName" class="form-control" @bind="patientName" placeholder="Enter patient name">
                </div>
            </div>

            <div class="mb-3">
                <label for="fileInput" class="form-label">Select Images:</label>
                <InputFile id="fileInput" OnChange="@OnInputFileChange" multiple class="form-control" />
            </div>

            @if (selectedFiles.Any())
            {
                <div class="alert alert-secondary py-2 mb-3">
                    <h6 class="mb-2">Staged Files (@selectedFiles.Count):</h6>
                    <ul class="mb-0 small">
                        @foreach (var file in selectedFiles)
                        {
                            <li>@file.Name (@(file.Size / 1024) KB)</li>
                        }
                    </ul>
                </div>
            }

            <button class="btn btn-success" @onclick="UploadImages" disabled="@(!CanUpload || isUploading)">
                @if (isUploading)
                {
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                    <span> Uploading...</span>
                }
                else
                {
                    <span>Upload to Server</span>
                }
            </button>

            @if (!string.IsNullOrEmpty(uploadResultMessage))
            {
                <div class="mt-3 alert @(uploadResultClass) alert-dismissible fade show" role="alert">
                    @uploadResultMessage
                    <button type="button" class="btn-close" @onclick="() => uploadResultMessage = null" aria-label="Close"></button>
                </div>
            }
        </div>
    </div>

    @if (images != null && images.Any())
    {
        <div class="row row-cols-1 row-cols-md-4 g-4">
            @foreach (var img in images)
            {
                <div class="col">
                    <div class="card h-100">
                        <img src="@(ApiService.BaseUrl + img.DownloadUrl?.TrimStart('/'))" class="card-img-top" alt="@img.OriginalFileName" style="height: 150px; object-fit: cover;">
                        <div class="card-body">
                            <p class="card-text small text-truncate">@img.OriginalFileName</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (!isUploading)
    {
        <div class="alert alert-info">No images uploaded yet.</div>
    }

    <div class="mt-4">
        <a href="/compose" class="btn btn-primary btn-lg">Go to Composer</a>
    </div>
</div>

@code {

    private List<ImageMetadata> images = new();

    private bool isUploading = false;

        private string patientName = string.Empty;

        private List<IBrowserFile> selectedFiles = new();

        private string? uploadResultMessage;

        private string uploadResultClass = "alert-info";

    

        private bool CanUpload => !string.IsNullOrWhiteSpace(patientName) && selectedFiles.Any();

    



    protected override async Task OnInitializedAsync()

    {

        await LoadImages();

    }



    private async Task LoadImages()

    {

        images = await ApiService.GetImagesAsync();

    }



    private void OnInputFileChange(InputFileChangeEventArgs e)

    {

        selectedFiles = e.GetMultipleFiles().ToList();

    }



        private async Task UploadImages()



        {



            if (!CanUpload) return;



    



            isUploading = true;



            uploadResultMessage = null;



            try



            {



                var content = new MultipartFormDataContent();



                            foreach (var file in selectedFiles)



                            {



                                var fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize: AppConstants.MaxFileSizeInBytes));



                                fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);



                                content.Add(fileContent, "files", file.Name);



                            }



                



    



                var result = await ApiService.UploadImagesAsync(content, patientName);



                



                uploadResultMessage = $"Successfully uploaded {result.Count} images for {patientName}.";



                uploadResultClass = "alert-success";



    



                // Reset after successful upload



                selectedFiles.Clear();



                patientName = string.Empty;



                await LoadImages();



            }



            catch (Exception ex)



            {



                Console.WriteLine($"Error uploading files: {ex.Message}");



                uploadResultMessage = $"Upload failed: {ex.Message}";



                uploadResultClass = "alert-danger";



            }



            finally



            {



                isUploading = false;



            }



        }



    

}
